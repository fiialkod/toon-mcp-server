{
  "name": "@fiialkod/toon-mcp-server",
  "version": "1.2.0",
  "description": "MCP server providing TOON format encoding/decoding for token-efficient LLM data exchange",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "toon-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run build && node test.mjs",
    "benchmark": "npm run build && node benchmark.mjs"
  },
  "keywords": [
    "mcp",
    "toon",
    "token-efficient",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@ason-format/ason": "^2.0.0-preview",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.32",
    "zon-format": "^1.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^25.4.0",
    "typescript": "^5.8.3"
  }
}
